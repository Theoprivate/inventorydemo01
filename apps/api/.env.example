# local = บัญชีทดสอบจากค่าด้านล่าง, sheets = อ่านผู้ใช้จาก Google Sheets
AUTH_MODE=local
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
SESSION_SECRET=change-this-to-a-long-random-value

DEV_AUTH_USER_ID=U001
DEV_AUTH_USERNAME=admin
DEV_AUTH_PASSWORD=admin123
DEV_AUTH_DISPLAY_NAME=ผู้ดูแลระบบ
DEV_AUTH_ROLE=admin

# Required only when AUTH_MODE=sheets
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
