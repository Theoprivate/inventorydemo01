PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
JWT_SECRET=
COOKIE_NAME=restaurant_session
NODE_ENV=development

GOOGLE_SHEET_ID=
# Optional local-only alternative: path is relative to apps/api and must be gitignored
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=

# Alternative for deployments that inject credentials as environment variables
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# The API uses the write-capable scope https://www.googleapis.com/auth/spreadsheets.
# Share the spreadsheet with the Service Account as Editor.
